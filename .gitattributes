# Normalize line endings. Shell scripts MUST stay LF or they break on Linux/macOS.
* text=auto
*.sh   text eol=lf
*.ps1  text eol=crlf
# Git hooks are shell scripts without an extension — keep them LF too.
.githooks/** text eol=lf
# Makefile recipes use tab indentation; CRLF appends a stray \r to each command on Linux/macOS.
Makefile text eol=lf
